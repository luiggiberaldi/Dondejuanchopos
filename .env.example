# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Plantilla de variables de entorno (PLACEHOLDERS, NO SECRETS REALES)
#
# IMPORTANTE (INFRA-001 / SEC-002): Este archivo NUNCA debe contener secretos reales.
# Copia a `.env` y rellena con tus valores. Los secretos comprometidos previamente
# (anon key de Supabase, token de Google Script, Exchangerate key) fueron rotados
# y eliminados del historial de git.
# ─────────────────────────────────────────────────────────────────────────────

# ── IA (Groq) ──
# Solo se usan en el dev server proxy (/api/analyze) o en el Cloudflare Worker.
# NUNCA se exponen al bundle del cliente.
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
GROQ_API_KEY_SECONDARY=YOUR_SECONDARY_GROQ_API_KEY_HERE

# ── Salt para derivación de claves de licencia (cliente) ──
# No es un secreto criptográfico (es público en el bundle), pero debe ser único
# por tenant para evitar rainbow tables cross-tenant.
VITE_LICENSE_SALT=CHANGE_ME_TO_A_UNIQUE_PER_TENANT_STRING

# ── Supabase (Estación Maestra / licenciamiento) ──
# El cliente Supabase del backend de licencias. La anon key es pública por diseño
# (RLS debe proteger los datos), pero RÓTALA si fue comprometida.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE

# ── Supabase Cloud (Sync P2P entre dispositivos del mismo negocio) ──
# IMPORTANTE: La anon key DEBE estar protegida por RLS estricta basada en auth.uid().
# Nunca uses USING(true) en tablas con PII.
VITE_SUPABASE_CLOUD_URL=https://YOUR-CLOUD-PROJECT.supabase.co
VITE_SUPABASE_CLOUD_KEY=YOUR_SUPABASE_CLOUD_ANON_KEY_HERE

# ── Tasas de cambio ──
# API key para exchangerate.host o similar (opcional, solo si se usa).
VITE_EXCHANGERATE_KEY=YOUR_EXCHANGERATE_KEY_HERE

# Google Apps Script que sirve tasas BCV. El token es un secreto compartido;
# si lo rotas, actualízalo también en el script de Google.
VITE_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec?token=YOUR_TOKEN_HERE

# ── CORS whitelist (INFRA-005) ──
# Lista separada por comas de orígenes permitidos para el Worker.
# NO uses '*' en producción.
VITE_ALLOWED_ORIGINS=https://app.preciosaldia.com,https://bodega.preciosaldia.com

# ── Feature flags ──
# Activa logs de debug solo en dev.
VITE_DEBUG=false
